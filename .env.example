# ============================================================
# creapopop 创作页 - 环境变量模板
# 复制为 .env 并填入真实值。.env 不入库（见 .gitignore）。
# 所有模型 key 仅存在于后端，前端源码/产物不出现任何 key。
# ============================================================

# ── 服务端口 ──
PORT=9527

# ── Arca 后端（海外正式后端）──
# 开发期走 vite proxy（/api → i18n-api.imaginewithu.com），无需配此变量。
# 生产构建时设为完整域名：
# VITE_API_BASE_URL=https://i18n-api.imaginewithu.com
ARCA_APP_KEY=
ARCA_APP_SECRET=
ARCA_TOKEN=

# ── 通用聊天模型（人设润色 / 试聊预览）──
# 复用旧创作工具的 Ark / OpenRouter 调用方式
SHARED_ARK_API_KEY=
SHARED_ARK_GEN_MODEL=
SHARED_OR_API_KEY=
SHARED_OR_MODEL=google/gemini-2.5-flash

# ── 生图模型（角色头像 / 立绘）──
APIMART_API_BASE=https://api.apimart.ai
APIMART_API_KEY=

# ── 代码模型（角色介绍展示页 UI 生成）──
# 调用方式 / 模型名待补充（参考旧创作端类似场景后填入）
CODE_MODEL_API_BASE=
CODE_MODEL_API_KEY=
CODE_MODEL_NAME=

# ── 可选 ──
ALLOWED_ORIGINS=
